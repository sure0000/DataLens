{
  "_description": "零售供应链域本体数据 — 对应 OntologyWriter 输入格式。可直接用于 POST /api/ontology/knowledge-bases/{kb_id}/terms, /metrics 等 API。",
  "_domain": "supply_chain",
  "_kb_id": "kb_retail_supply_chain",

  "business_terms": [
    {
      "domain_id": 10,
      "name": "SKU 编码",
      "definition": "企业内唯一标识一个可售商品的编码，12位数字，前4位为品类码，后8位为流水号",
      "term_type": "dimension",
      "related_fields": ["scm.product.sku_code", "trade.order_line.sku_code", "wms.inventory.item_id"],
      "confidence": 100,
      "status": "approved"
    },
    {
      "domain_id": 10,
      "name": "在库数量",
      "definition": "仓库中实际可用的商品数量，on_hand_qty - reserved_qty。包含在途未入库的数量，不含已锁定/冻结的数量。",
      "term_type": "metric",
      "related_fields": ["scm.inventory_snapshot.on_hand_qty", "scm.inventory_snapshot.reserved_qty"],
      "confidence": 100,
      "status": "approved"
    },
    {
      "domain_id": 10,
      "name": "采购单状态",
      "definition": "采购单在其生命周期中所处的阶段：draft（草稿）、submitted（已提交）、approved（已审批）、received（已收货）、closed（已关闭）",
      "term_type": "enum",
      "related_fields": ["scm.purchase_order.status"],
      "confidence": 100,
      "status": "approved"
    },
    {
      "domain_id": 10,
      "name": "供应商编码",
      "definition": "企业内唯一标识一个供应商的编码，与 ERP 系统供应商编码一致",
      "term_type": "dimension",
      "related_fields": ["scm.supplier.supplier_code", "scm.purchase_order.supplier_code"],
      "confidence": 100,
      "status": "approved"
    },
    {
      "domain_id": 10,
      "name": "门店编码",
      "definition": "企业内物理门店的唯一编码，POS 系统、电商平台共享此编码",
      "term_type": "dimension",
      "related_fields": ["scm.store.store_code", "trade.order_header.store_code"],
      "confidence": 100,
      "status": "approved"
    }
  ],

  "metrics": [
    {
      "domain_id": 10,
      "name": "日销售额",
      "formula": "SUM(trade.order_header.paid_amount) WHERE status IN ('paid','shipped','delivered')",
      "caliber": "分子：实付金额 SUM；时间窗口：自然日（biz_date）；排除条件：status = 'cancelled'；含运费不含退款",
      "bound_table_ids": [201],
      "derived_from_metric_id": null,
      "confidence": 100,
      "status": "approved"
    },
    {
      "domain_id": 10,
      "name": "毛利率",
      "formula": "(SUM(trade.order_line.paid_amount) - SUM(trade.order_line.cost_amt)) / SUM(trade.order_line.paid_amount) * 100",
      "caliber": "cost_amt 按采购加权移动平均成本，从 SCM 域获取；时间窗口：自然月；过滤：排除已取消和已退款订单",
      "bound_table_ids": [201, 202],
      "derived_from_metric_id": null,
      "confidence": 95,
      "status": "approved"
    },
    {
      "domain_id": 10,
      "name": "库存周转天数",
      "formula": "AVG(scm.inventory_snapshot.on_hand_qty) OVER 30 days / SUM(scm.outbound_delivery.qty) OVER 30 days * 30",
      "caliber": "按 SKU + 仓库粒度逐日计算月均库存，排除 on_hand_qty=0 的行；节假日顺延",
      "bound_table_ids": [103, 106],
      "derived_from_metric_id": null,
      "confidence": 80,
      "status": "pending_review"
    },
    {
      "domain_id": 10,
      "name": "准时交付率",
      "formula": "COUNT(CASE WHEN inbound_receipt.qty >= purchase_order_line.ordered_qty THEN 1 END) / COUNT(*) * 100",
      "caliber": "按 PO 行项独立评价；仅统计 status='received' 的行项；时间窗口：自然月；冗余：包含部分到货也算足量",
      "bound_table_ids": [102, 104],
      "derived_from_metric_id": null,
      "confidence": 60,
      "status": "draft"
    },
    {
      "domain_id": 10,
      "name": "客单价",
      "formula": "SUM(trade.order_header.paid_amount) / COUNT(DISTINCT trade.order_header.order_id)",
      "caliber": "分子 = GMV；分母 = 去重订单数；排除取消订单；时间窗口：自然日",
      "bound_table_ids": [201],
      "derived_from_metric_id": null,
      "confidence": 100,
      "status": "approved"
    }
  ],

