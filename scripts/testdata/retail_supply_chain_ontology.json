  "business_rules": [
    {
      "kb_id": "kb_retail_supply_chain",
      "rule_type": "validation",
      "rule_name": "采购金额必须大于零",
      "rule_expression": "purchase_order.total_amount > 0",
      "confidence": 100,
      "status": "approved"
    },
    {
      "kb_id": "kb_retail_supply_chain",
      "rule_type": "validation",
      "rule_name": "库存数量不得为负",
      "rule_expression": "inventory_snapshot.on_hand_qty >= 0",
      "confidence": 100,
      "status": "approved"
    },
    {
      "kb_id": "kb_retail_supply_chain",
      "rule_type": "constraint",
      "rule_name": "采购单状态流转规则",
      "rule_expression": "status: draft → submitted → approved → received → closed",
      "confidence": 100,
      "status": "approved"
    },
    {
      "kb_id": "kb_retail_supply_chain",
      "rule_type": "derivation",
      "rule_name": "采购行金额计算",
      "rule_expression": "line_total = ordered_qty * unit_price",
      "confidence": 100,
      "status": "approved"
    },
    {
      "kb_id": "kb_retail_supply_chain",
      "rule_type": "constraint",
      "rule_name": "仅活跃供应商可创建采购单",
      "rule_expression": "supplier.status = 'active' 方可创建 purchase_order",
      "confidence": 90,
      "status": "approved"
    },
    {
      "kb_id": "kb_retail_supply_chain",
      "rule_type": "constraint",
      "rule_name": "预留库存不超在库量",
      "rule_expression": "inventory_snapshot.reserved_qty <= inventory_snapshot.on_hand_qty",
      "confidence": 100,
      "status": "approved"
    }
  ],

