  "_cross_domain_notes": [
    {
      "issue": "SKU 编码跨域一致性问题",
      "detail": "SCM 和 Trade 中 SKU 格式一致（varchar(12)），但 WMS 中为 int 类型（去掉品类码前缀）。跨域 JOIN 时需 CAST，或建议 WMS 统一为 varchar。",
      "severity": "medium",
      "suggested_fix": "在 ODS 层统一 SKU 格式，或在 concept_alias 中注册转换规则"
    },
    {
      "issue": "时间维度口径不一致",
      "detail": "采购域使用 biz_date（业务归属日），交易域使用 created_at（系统时间戳）。跨域分析时若混用会导致日期错位。",
      "severity": "high",
      "suggested_fix": "跨域分析统一使用 biz_date，各域在 DWD 层必须产出 biz_date 字段"
    },
    {
      "issue": "库存金额双口径",
      "detail": "SCM 域使用「最近采购价 × 在库量」，财务域使用「加权移动平均成本 × 在库量」。两者在原料价格波动期差异显著。",
      "severity": "medium",
      "suggested_fix": "两个口径都保留，分别注册为 metric.inventory_value_scm 和 metric.inventory_value_fin"
    }
  ]
}
