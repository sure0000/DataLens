@prefix sh:   <http://www.w3.org/ns/shacl#> .
@prefix dl:   <https://datalens.local/ontology/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .

dl:TermShape a sh:NodeShape ;
  sh:targetClass dl:BusinessTerm ;
  sh:severity sh:Violation ;
  sh:property [
    sh:path skos:prefLabel ;
    sh:name "首选标签"@zh ;
    sh:description "每个术语必须有一个首选标签"@zh ;
    sh:minCount 1 ;
    sh:datatype xsd:string ;
  ] ;
  sh:property [
    sh:path skos:definition ;
    sh:name "定义"@zh ;
    sh:description "每个术语必须有一条业务定义"@zh ;
    sh:minCount 1 ;
    sh:datatype xsd:string ;
  ] ;
  sh:property [
    sh:path dl:belongsToDomain ;
    sh:name "归属领域"@zh ;
    sh:description "每个术语必须归属到一个业务域"@zh ;
    sh:minCount 1 ;
  ] ;
  sh:property [
    sh:path dl:confidence ;
    sh:name "置信度"@zh ;
    sh:minInclusive 0.0 ;
    sh:maxInclusive 100.0 ;
    sh:datatype xsd:decimal ;
  ] ;
  sh:property [
    sh:path dl:approvalStatus ;
    sh:name "审批状态"@zh ;
    sh:in ("approved" "pending_review" "draft" "rejected") ;
    sh:datatype xsd:string ;
  ] .
