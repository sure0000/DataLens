@prefix owl:    <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:   <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema: <https://schema.org/> .
@prefix dl:     <https://datalens.local/ontology/> .

dl:PhysicalTable rdfs:subClassOf schema:Table .
dl:PhysicalColumn rdfs:subClassOf schema:PropertyValue .

schema:isPartOf a owl:ObjectProperty ;
  rdfs:domain dl:PhysicalColumn ;
  rdfs:range dl:PhysicalTable .
