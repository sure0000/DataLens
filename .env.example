DATABASE_URL=postgresql://postgres:password@localhost:5432/datalens
DB_SCHEMA_MANAGEMENT_MODE=legacy
DEEPSEEK_API_KEY=
OPENAI_API_KEY=
# 可选；OpenAI 官方或代理的 API 根地址（偏好设置里填的 URL 会覆盖此项）
OPENAI_BASE_URL=
BACKEND_PORT=8000
FRONTEND_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:8000
API_AUTH_ENABLED=true
API_AUTH_TOKEN=datalens-dev-token
NEXT_PUBLIC_API_TOKEN=datalens-dev-token
# 浏览器跨域：同时允许 localhost 与 127.0.0.1 访问前端
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# 允许常见内网地址来源（例如 http://192.168.x.x:3000）；留空可禁用
CORS_ORIGIN_REGEX=^https?://(localhost|127\.0\.0\.1|10\.\d+\.\d+\.\d+|192\.168\.\d+\.\d+|172\.(1[6-9]|2\d|3[0-1])\.\d+\.\d+)(:\d+)?$
# Copilot 未选业务域时，语义 top_k 硬上限（默认 20，非 2000）
COPILOT_MAX_TABLES_WITHOUT_DOMAIN=20
# 为 true 时，SQL 校验需 review 则跳过自动执行；默认 false（仍执行并提示风险）
# COPILOT_SQL_REVIEW_BLOCKS_EXECUTION=false
# 知识库语义结构化
SEMANTIC_CHUNK_STRUCTURE_MAX=40
SEMANTIC_AUTO_APPROVE_CONFIDENCE=80
# Formal OWL 本体层 — RDF 默认写入 Fuseki（本地 Java 或 Docker，同一端口）
ONTOLOGY_ENABLED=true
FUSEKI_URL=http://localhost:3030
FUSEKI_DATASET=datalens
FUSEKI_IMAGE=stain/jena-fuseki:4.10.0
FUSEKI_ADMIN_PASSWORD=admin
FUSEKI_AUTO_START=true
# 注意：该开关仅用于后端配置；`./scripts/service.sh start local` 不会自动启动 Docker Fuseki
# Fuseki 不可达时是否允许内存回退（不持久化；生产请保持 false）
FUSEKI_FALLBACK_MEMORY=false
# 出站 HTTP 是否使用系统代理（ALL_PROXY/HTTP_PROXY）。代理未启动导致 SSL EOF 时可设为 false
# DATALENS_HTTP_TRUST_ENV=true
# 仅调试：回退到本地 Trig 文件（默认关闭）
# ONTOLOGY_LOCAL_STORE_ENABLED=true
# ONTOLOGY_LOCAL_STORE_PATH=.run/ontology-store/datalens.trig
