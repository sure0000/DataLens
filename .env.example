DATABASE_URL=postgresql://postgres:password@localhost:5432/datalens
DEEPSEEK_API_KEY=
OPENAI_API_KEY=
# 可选；OpenAI 官方或代理的 API 根地址（偏好设置里填的 URL 会覆盖此项）
OPENAI_BASE_URL=
BACKEND_PORT=8000
FRONTEND_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:8000
# Copilot 未选业务域时，语义 top_k 硬上限（默认 20，非 2000）
COPILOT_MAX_TABLES_WITHOUT_DOMAIN=20
# 知识库语义结构化
SEMANTIC_CHUNK_STRUCTURE_MAX=40
SEMANTIC_AUTO_APPROVE_CONFIDENCE=80
